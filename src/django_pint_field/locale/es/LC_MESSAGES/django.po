#: widgets.py
msgid "PintFieldWidgets require a default_unit kwarg of a single Pint unit type (eg: 'grams')"
msgstr "PintFieldWidgets requiere un argumento default_unit con un solo tipo de unidad Pint (ej: 'grams')"

#: widgets.py forms.py
msgid "default_unit must be either a string or a 2-tuple/2-list of (display_name, unit_value)"
msgstr "default_unit debe ser una cadena o una tupla/lista de 2 elementos (nombre_mostrado, valor_unidad)"

#: widgets.py
msgid "Quantity magnitude"
msgstr "Magnitud de la cantidad"

#: widgets.py
msgid "Quantity unit"
msgstr "Unidad de la cantidad"

#: forms.py
msgid "PintFormField requires a default_unit kwarg of a single unit type (eg: 'grams')"
msgstr "PintFormField requiere un argumento default_unit con un solo tipo de unidad (ej: 'grams')"

#: rest.py
msgid "Invalid magnitude value."
msgstr "Valor de magnitud no válido."

#: rest.py
msgid "Invalid or undefined unit."
msgstr "Unidad no válida o no definida."

#: rest.py
msgid "Both magnitude and units are required."
msgstr "Se requieren tanto la magnitud como las unidades."

#: rest.py
msgid "Incompatible unit dimensions."
msgstr "Dimensiones de unidad incompatibles."

#: rest.py
msgid "Invalid format. Expected \"number unit\" or Quantity object."
msgstr "Formato no válido. Se esperaba \"número unidad\" u objeto Quantity."

#: templates/django_pint_field/tabled_django_pint_field_widget.html
msgid "Unit conversion reference"
msgstr "Referencia de conversión de unidades"

#: templates/django_pint_field/tabled_django_pint_field_widget.html
msgid "Converted values in different units"
msgstr "Valores convertidos en diferentes unidades"

#: templates/django_pint_field/tabled_django_pint_field_widget.html
msgid "Unit"
msgstr "Unidad"

#: templates/django_pint_field/tabled_django_pint_field_widget.html
msgid "Value"
msgstr "Valor"
